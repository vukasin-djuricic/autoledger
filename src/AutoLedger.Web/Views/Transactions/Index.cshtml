@model TransactionsIndexViewModel
@using System.Globalization
@{
    ViewData["Title"] = "Transactions";
    var pg = Model.Page;
    var currentStatus = Model.Status?.ToString();
    var from = pg.TotalCount == 0 ? 0 : (pg.Page - 1) * pg.PageSize + 1;
    var to = Math.Min(pg.Page * pg.PageSize, pg.TotalCount);
}
<div class="mx-auto max-w-5xl">
    @if (TempData["Message"] is string msg)
    {
        <div class="mb-4 rounded-lg bg-emerald-50 px-4 py-2.5 text-sm font-medium text-emerald-700">@msg</div>
    }

    <div class="mb-6 flex flex-wrap items-end justify-between gap-4">
        <div>
            <h1 class="text-[26px] font-semibold tracking-tight text-stone-900">Transactions</h1>
            <p class="mt-1 text-sm text-stone-400 tnum">@pg.TotalCount journal entries</p>
        </div>
    </div>

    <!-- FILTERS -->
    <div class="mb-4 flex flex-wrap items-center gap-1.5 text-sm">
        @foreach (var (label, value) in TransactionsIndexViewModel.Filters)
        {
            var active = value?.ToString() == currentStatus;
            <a href="@Url.Action("Index", new { status = value?.ToString() })"
               class="rounded-full px-3 py-1.5 text-xs font-medium @(active ? "bg-stone-900 text-white" : "text-stone-500 hover:bg-stone-100")">@label</a>
        }
    </div>

    <!-- TABLE CARD -->
    <div class="overflow-hidden rounded-2xl border border-stone-200/80 bg-white shadow-sm">
        @if (pg.Items.Count == 0)
        {
            <div class="flex flex-col items-center justify-center px-6 py-20 text-center">
                <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-stone-100 text-stone-400">
                    <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24"><path d="M17 21H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h7l5 5v11a2 2 0 0 1-2 2z"/></svg>
                </div>
                <h3 class="mt-4 text-base font-semibold text-stone-800">No transactions yet</h3>
                <p class="mt-1 max-w-xs text-sm text-stone-400">Nothing matches this filter. Create your first entry to get started.</p>
                <a href="@Url.Action("Create", "JournalEntries")" class="mt-5 flex items-center gap-1.5 rounded-lg bg-brand-700 px-4 py-2 text-sm font-medium text-white hover:bg-brand-600"><svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg> New Entry</a>
            </div>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-stone-100 text-left text-[11px] uppercase tracking-wide text-stone-400">
                            <th class="px-5 py-3 font-semibold">Date</th>
                            <th class="px-5 py-3 font-semibold">Entry</th>
                            <th class="px-5 py-3 font-semibold">Description</th>
                            <th class="px-5 py-3 font-semibold">Account</th>
                            <th class="px-5 py-3 font-semibold text-right">Amount</th>
                            <th class="px-5 py-3 font-semibold">Status</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-stone-50">
                        @foreach (var e in pg.Items)
                        {
                            var account = e.Lines.FirstOrDefault()?.Account;
                            <tr class="cursor-pointer hover:bg-stone-50" onclick="location.href='@Url.Action("Details", "JournalEntries", new { id = e.Id })'">
                                <td class="whitespace-nowrap px-5 py-4 text-stone-400 tnum">@e.Date.ToString("dd MMM", CultureInfo.InvariantCulture)</td>
                                <td class="whitespace-nowrap px-5 py-4 font-medium text-stone-800 tnum">@e.ReferenceNumber</td>
                                <td class="px-5 py-4 text-stone-600">@e.Description</td>
                                <td class="whitespace-nowrap px-5 py-4 text-stone-400 tnum">@(account is null ? "—" : $"{account.Code} · {account.Name}")</td>
                                <td class="whitespace-nowrap px-5 py-4 text-right font-medium text-stone-800 tnum">@Money.Format(e.TotalDebit)</td>
                                <td class="px-5 py-4">@await Component.InvokeAsync("StatusBadge", new { status = e.Status })</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="flex flex-wrap items-center justify-between gap-3 border-t border-stone-100 px-5 py-3 text-sm">
                <p class="text-stone-400 tnum">@from–@to of @pg.TotalCount</p>
                <div class="flex items-center gap-1">
                    @if (pg.Page > 1)
                    {
                        <a href="@Url.Action("Index", new { status = currentStatus, page = pg.Page - 1 })" class="rounded-md px-2.5 py-1.5 text-stone-500 hover:bg-stone-100">Prev</a>
                    }
                    else
                    {
                        <span class="rounded-md px-2.5 py-1.5 text-stone-300">Prev</span>
                    }
                    @for (var p = 1; p <= pg.TotalPages; p++)
                    {
                        if (p == pg.Page)
                        {
                            <span class="rounded-md bg-brand-700 px-3 py-1.5 font-medium text-white tnum">@p</span>
                        }
                        else
                        {
                            <a href="@Url.Action("Index", new { status = currentStatus, page = p })" class="rounded-md px-3 py-1.5 text-stone-500 hover:bg-stone-100 tnum">@p</a>
                        }
                    }
                    @if (pg.Page < pg.TotalPages)
                    {
                        <a href="@Url.Action("Index", new { status = currentStatus, page = pg.Page + 1 })" class="rounded-md px-2.5 py-1.5 text-stone-500 hover:bg-stone-100">Next</a>
                    }
                    else
                    {
                        <span class="rounded-md px-2.5 py-1.5 text-stone-300">Next</span>
                    }
                </div>
            </div>
        }
    </div>
</div>
