@model IReadOnlyList<Vendor>
@{
    ViewData["Title"] = "Vendors";
    var isController = User.IsInRole(Roles.Controller);
}
<div class="mx-auto max-w-3xl">
    <div class="mb-6 flex items-end justify-between gap-4">
        <div>
            <h1 class="text-[26px] font-semibold tracking-tight text-stone-900">Vendors</h1>
            <p class="mt-1 text-sm text-stone-400">Counterparties entries can be linked to for risk scoring.</p>
        </div>
        @if (isController)
        {
            <a href="@Url.Action("Create")" class="flex shrink-0 items-center gap-1.5 rounded-lg bg-brand-700 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-brand-600">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg> New vendor
            </a>
        }
    </div>

    @if (TempData["Message"] is string msg)
    {
        <div class="mb-4 rounded-lg bg-emerald-50 px-4 py-2.5 text-sm font-medium text-emerald-700">@msg</div>
    }

    <div class="overflow-hidden rounded-2xl border border-stone-200/80 bg-white shadow-sm">
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-stone-100 text-left text-[11px] uppercase tracking-wide text-stone-400">
                        <th class="px-5 py-3 font-semibold">Name</th>
                        <th class="px-5 py-3 font-semibold">Status</th>
                        @if (isController) { <th class="px-5 py-3"></th> }
                    </tr>
                </thead>
                <tbody class="divide-y divide-stone-50">
                    @foreach (var v in Model)
                    {
                        <tr class="hover:bg-stone-50 @(v.IsActive ? "" : "opacity-60")">
                            <td class="px-5 py-3 font-medium text-stone-800">@v.Name</td>
                            <td class="px-5 py-3">
                                @if (v.IsActive)
                                {
                                    <span class="rounded-full bg-emerald-100 px-2 py-0.5 text-[11px] font-semibold text-emerald-700">Active</span>
                                }
                                else
                                {
                                    <span class="rounded-full bg-stone-100 px-2 py-0.5 text-[11px] font-semibold text-stone-500">Inactive</span>
                                }
                            </td>
                            @if (isController)
                            {
                                <td class="px-5 py-3 text-right">
                                    <div class="flex items-center justify-end gap-2">
                                        <a href="@Url.Action("Edit", new { id = v.Id })" class="font-medium text-stone-500 hover:text-stone-800">Edit</a>
                                        <form asp-action="ToggleActive" method="post" class="inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@v.Id" />
                                            <button type="submit" class="font-medium text-stone-400 hover:text-stone-700">@(v.IsActive ? "Deactivate" : "Activate")</button>
                                        </form>
                                    </div>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
