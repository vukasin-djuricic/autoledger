@model CreateJournalEntryViewModel
@{
    ViewData["Title"] = "New Journal Entry";
}
<div class="mx-auto max-w-3xl">
    <div class="mb-6">
        <h1 class="text-[26px] font-semibold tracking-tight text-stone-900">New Journal Entry</h1>
        <p class="mt-1 text-sm text-stone-400">Debits must equal credits before you can submit.</p>
    </div>

    <form asp-action="Create" method="post" id="entryForm">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="mb-4 rounded-lg bg-rose-50 px-4 py-2.5 text-sm text-rose-700 empty:hidden"></div>

        <!-- HEADER FIELDS -->
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            <div>
                <label asp-for="Date" class="mb-1.5 block text-xs font-medium text-stone-500">Entry date</label>
                <input asp-for="Date" type="date" class="w-full rounded-lg border border-stone-200 bg-white px-3 py-2 text-sm text-stone-700 tnum focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-100" />
            </div>
            <div>
                <label asp-for="Reference" class="mb-1.5 block text-xs font-medium text-stone-500">Reference</label>
                <input asp-for="Reference" placeholder="e.g. INV-88421" class="w-full rounded-lg border border-stone-200 bg-white px-3 py-2 text-sm text-stone-700 placeholder-stone-400 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-100" />
            </div>
            <div>
                <label asp-for="VendorId" class="mb-1.5 block text-xs font-medium text-stone-500">Vendor (optional)</label>
                <select asp-for="VendorId" class="w-full rounded-lg border border-stone-200 bg-white px-3 py-2 text-sm text-stone-700 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-100">
                    <option value="">— none —</option>
                    @foreach (var v in Model.VendorOptions)
                    {
                        <option value="@v.Value">@v.Text</option>
                    }
                </select>
            </div>
            <div>
                <label asp-for="Description" class="mb-1.5 block text-xs font-medium text-stone-500">Description</label>
                <input asp-for="Description" placeholder="Memo describing this entry…" class="w-full rounded-lg border border-stone-200 bg-white px-3 py-2 text-sm text-stone-700 placeholder-stone-400 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-100" />
            </div>
        </div>

        <!-- LINES -->
        <div class="mt-6">
            <div class="mb-2 flex items-center justify-between px-1">
                <h2 class="text-sm font-medium text-stone-500">Journal Lines</h2>
                <button type="button" id="addLine" class="flex items-center gap-1.5 text-xs font-medium text-brand-700 hover:text-brand-600">
                    <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg> Add line
                </button>
            </div>

            <div class="overflow-hidden rounded-2xl border border-stone-200/80 bg-white">
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="border-b border-stone-100 text-left text-[11px] uppercase tracking-wide text-stone-400">
                                <th class="px-4 py-2.5 font-semibold" style="min-width:200px">Account</th>
                                <th class="px-4 py-2.5 font-semibold text-right" style="width:140px">Debit</th>
                                <th class="px-4 py-2.5 font-semibold text-right" style="width:140px">Credit</th>
                                <th class="px-2 py-2.5" style="width:40px"></th>
                            </tr>
                        </thead>
                        <tbody id="lines">
                            @for (var i = 0; i < Model.Lines.Count; i++)
                            {
                                <tr class="line-row border-b border-stone-50">
                                    <td class="px-4 py-2.5">
                                        <select name="Lines[@i].AccountId" class="line-account w-full rounded-lg border border-stone-200 bg-white px-2.5 py-1.5 text-sm text-stone-700 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-100">
                                            <option value="">Select account…</option>
                                            @foreach (var a in Model.AccountOptions)
                                            {
                                                <option value="@a.Value" selected="@(Model.Lines[i].AccountId?.ToString() == a.Value)">@a.Text</option>
                                            }
                                        </select>
                                    </td>
                                    <td class="px-4 py-2.5">
                                        <div class="relative"><span class="pointer-events-none absolute left-2.5 top-1/2 -translate-y-1/2 text-xs text-stone-400">€</span>
                                            <input name="Lines[@i].Debit" value="@(Model.Lines[i].Debit)" type="number" step="0.01" min="0" placeholder="0,00" class="line-debit w-full rounded-lg border border-stone-200 bg-white py-1.5 pl-6 pr-2.5 text-right text-sm text-stone-800 tnum placeholder-stone-300 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-100" /></div>
                                    </td>
                                    <td class="px-4 py-2.5">
                                        <div class="relative"><span class="pointer-events-none absolute left-2.5 top-1/2 -translate-y-1/2 text-xs text-stone-400">€</span>
                                            <input name="Lines[@i].Credit" value="@(Model.Lines[i].Credit)" type="number" step="0.01" min="0" placeholder="0,00" class="line-credit w-full rounded-lg border border-stone-200 bg-white py-1.5 pl-6 pr-2.5 text-right text-sm text-stone-800 tnum placeholder-stone-300 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-100" /></div>
                                    </td>
                                    <td class="px-2 py-2.5 text-center">
                                        <button type="button" class="remove-line flex h-7 w-7 items-center justify-center rounded-lg text-stone-300 hover:bg-rose-50 hover:text-rose-500"><svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6"/></svg></button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- LIVE BALANCE -->
        <div id="balPill" class="mt-4 flex flex-wrap items-center justify-between gap-3 rounded-2xl px-5 py-4 ring-1 ring-inset">
            <div class="flex items-center gap-6 text-sm">
                <div><span class="text-xs text-stone-400">Debit</span><div id="sumDebit" class="tnum text-base font-semibold text-stone-900">€0,00</div></div>
                <div><span class="text-xs text-stone-400">Credit</span><div id="sumCredit" class="tnum text-base font-semibold text-stone-900">€0,00</div></div>
            </div>
            <div class="flex items-center gap-2.5">
                <span id="balIcon" class="flex h-7 w-7 items-center justify-center rounded-full"></span>
                <div class="leading-tight text-right">
                    <div id="balLabel" class="text-sm font-semibold"></div>
                    <div class="text-xs"><span class="opacity-70">Difference</span> <span id="balDiff" class="tnum font-semibold"></span></div>
                </div>
            </div>
        </div>

        <!-- ACTIONS -->
        <div class="mt-5 flex items-center justify-end gap-2">
            <a href="@Url.Action("Index", "Transactions")" class="rounded-lg px-4 py-2 text-sm font-medium text-stone-500 hover:bg-stone-100">Cancel</a>
            <button type="submit" id="submitBtn" class="flex items-center gap-1.5 rounded-lg px-4 py-2 text-sm font-semibold text-white shadow-sm">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg> Submit for Approval
            </button>
        </div>
    </form>
</div>

@section Scripts {
<script>
    const tbody = document.getElementById('lines');
    function fmt(n){ return '€' + n.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2}); }

    function reindex(){
        [...tbody.querySelectorAll('.line-row')].forEach((row, i) => {
            row.querySelector('.line-account').name = `Lines[${i}].AccountId`;
            row.querySelector('.line-debit').name   = `Lines[${i}].Debit`;
            row.querySelector('.line-credit').name  = `Lines[${i}].Credit`;
        });
    }

    function recalc(){
        let td = 0, tc = 0;
        tbody.querySelectorAll('.line-row').forEach(row => {
            td += parseFloat(row.querySelector('.line-debit').value) || 0;
            tc += parseFloat(row.querySelector('.line-credit').value) || 0;
        });
        const diff = td - tc, balanced = Math.abs(diff) < 0.005 && td > 0;
        document.getElementById('sumDebit').textContent = fmt(td);
        document.getElementById('sumCredit').textContent = fmt(tc);
        const pill = document.getElementById('balPill'), icon = document.getElementById('balIcon'),
              label = document.getElementById('balLabel'), dEl = document.getElementById('balDiff'),
              btn = document.getElementById('submitBtn');
        dEl.textContent = (diff >= 0 ? '€' : '−€') + Math.abs(diff).toLocaleString('de-DE',{minimumFractionDigits:2,maximumFractionDigits:2});
        if (balanced){
            pill.className = 'mt-4 flex flex-wrap items-center justify-between gap-3 rounded-2xl px-5 py-4 ring-1 ring-inset bg-emerald-50/60 ring-emerald-200';
            icon.className = 'flex h-7 w-7 items-center justify-center rounded-full bg-emerald-500 text-white';
            icon.innerHTML = '<svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg>';
            label.textContent = 'Balanced'; label.className = 'text-sm font-semibold text-emerald-700';
            dEl.className = 'tnum font-semibold text-emerald-700';
            btn.disabled = false; btn.className = 'flex items-center gap-1.5 rounded-lg bg-brand-700 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-brand-600 cursor-pointer';
        } else {
            pill.className = 'mt-4 flex flex-wrap items-center justify-between gap-3 rounded-2xl px-5 py-4 ring-1 ring-inset bg-rose-50/60 ring-rose-200';
            icon.className = 'flex h-7 w-7 items-center justify-center rounded-full bg-rose-500 text-white';
            icon.innerHTML = '<svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path d="M12 8v5M12 17h.01"/></svg>';
            label.textContent = (td === 0 ? 'No amounts entered' : 'Out of balance'); label.className = 'text-sm font-semibold text-rose-700';
            dEl.className = 'tnum font-semibold text-rose-700';
            btn.disabled = true; btn.className = 'flex items-center gap-1.5 rounded-lg bg-stone-200 px-4 py-2 text-sm font-semibold text-stone-400 shadow-sm cursor-not-allowed';
        }
    }

    tbody.addEventListener('input', e => {
        if (e.target.classList.contains('line-debit') && e.target.value !== ''){
            e.target.closest('.line-row').querySelector('.line-credit').value = '';
        } else if (e.target.classList.contains('line-credit') && e.target.value !== ''){
            e.target.closest('.line-row').querySelector('.line-debit').value = '';
        }
        recalc();
    });

    tbody.addEventListener('click', e => {
        const btn = e.target.closest('.remove-line');
        if (!btn) return;
        const rows = tbody.querySelectorAll('.line-row');
        if (rows.length > 1) btn.closest('.line-row').remove();
        reindex(); recalc();
    });

    document.getElementById('addLine').addEventListener('click', () => {
        const last = tbody.querySelector('.line-row');
        const clone = last.cloneNode(true);
        clone.querySelectorAll('input').forEach(i => i.value = '');
        clone.querySelector('.line-account').value = '';
        tbody.appendChild(clone);
        reindex(); recalc();
    });

    recalc();
</script>
}
