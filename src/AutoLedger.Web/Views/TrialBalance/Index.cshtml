@model TrialBalanceViewModel
@{
    ViewData["Title"] = "Trial Balance";
}
<div class="mx-auto max-w-3xl">
    <div class="mb-6">
        <h1 class="text-[26px] font-semibold tracking-tight text-stone-900">Trial Balance</h1>
        <p class="mt-1 text-sm text-stone-400">Net balance per account over all posted entries. Total debit must equal total credit.</p>
    </div>

    @if (Model.Rows.Count == 0)
    {
        <div class="rounded-2xl border border-stone-200/80 bg-white px-6 py-16 text-center shadow-sm">
            <h3 class="text-base font-semibold text-stone-800">Nothing posted yet</h3>
            <p class="mt-1 text-sm text-stone-400">The trial balance appears once entries are posted to the ledger.</p>
        </div>
        return;
    }

    <div class="overflow-hidden rounded-2xl border border-stone-200/80 bg-white shadow-sm">
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-stone-100 text-left text-[11px] uppercase tracking-wide text-stone-400">
                        <th class="px-5 py-3 font-semibold">Account</th>
                        <th class="px-5 py-3 font-semibold">Type</th>
                        <th class="px-5 py-3 font-semibold text-right">Debit</th>
                        <th class="px-5 py-3 font-semibold text-right">Credit</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-stone-50">
                    @foreach (var row in Model.Rows)
                    {
                        <tr class="cursor-pointer hover:bg-stone-50" onclick="location.href='@Url.Action("Ledger", new { accountId = row.AccountId })'">
                            <td class="px-5 py-3"><a href="@Url.Action("Ledger", new { accountId = row.AccountId })" class="font-medium text-stone-800 tnum hover:text-brand-700">@row.AccountCode</a> <span class="text-stone-500">@row.AccountName</span></td>
                            <td class="px-5 py-3 text-stone-400">@row.AccountType</td>
                            <td class="px-5 py-3 text-right tnum @(row.Debit > 0 ? "font-medium text-stone-800" : "text-stone-300")">@(row.Debit > 0 ? Money.Format(row.Debit) : "—")</td>
                            <td class="px-5 py-3 text-right tnum @(row.Credit > 0 ? "font-medium text-stone-800" : "text-stone-300")">@(row.Credit > 0 ? Money.Format(row.Credit) : "—")</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr class="border-t border-stone-200 bg-stone-50/70 text-sm font-semibold">
                        <td class="px-5 py-3 text-stone-500" colspan="2">Totals</td>
                        <td class="px-5 py-3 text-right text-stone-900 tnum">@Money.Format(Model.TotalDebit)</td>
                        <td class="px-5 py-3 text-right text-stone-900 tnum">@Money.Format(Model.TotalCredit)</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>

    <p class="mt-3 flex items-center justify-center gap-1.5 text-sm font-medium @(Model.IsBalanced ? "text-emerald-600" : "text-rose-600")">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg>
        @(Model.IsBalanced ? "In balance · the books tie out" : "Out of balance by " + Money.Format(Math.Abs(Model.TotalDebit - Model.TotalCredit)))
    </p>
</div>
