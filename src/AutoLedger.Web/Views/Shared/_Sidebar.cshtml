@inject IJournalEntryRepository JournalEntries
@inject UserManager<ApplicationUser> UserManager
@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
    string Cls(string c) => c == controller
        ? "flex items-center gap-3 rounded-lg bg-stone-100 px-3 py-2 font-medium text-stone-900"
        : "flex items-center gap-3 rounded-lg px-3 py-2 font-medium text-stone-500 hover:bg-stone-50 hover:text-stone-900";
    string IconCls(string c) => c == controller ? "h-[18px] w-[18px] text-brand-700" : "h-[18px] w-[18px]";
    // Active by controller AND action (for controllers with several report pages).
    string ClsA(string c, string a) => (c == controller && a == action)
        ? "flex items-center gap-3 rounded-lg bg-stone-100 px-3 py-2 font-medium text-stone-900"
        : "flex items-center gap-3 rounded-lg px-3 py-2 font-medium text-stone-500 hover:bg-stone-50 hover:text-stone-900";
    string IconClsA(string c, string a) => (c == controller && a == action) ? "h-[18px] w-[18px] text-brand-700" : "h-[18px] w-[18px]";

    var pending = await JournalEntries.CountByStatusAsync(JournalEntryStatus.PendingReview);
    var me = await UserManager.GetUserAsync(User);
    var displayName = me?.DisplayName ?? User.Identity?.Name ?? "—";
    var jobTitle = me?.JobTitle ?? (User.IsInRole("Controller") ? "Controller" : "Clerk");
    var initials = string.Concat(displayName.Split(' ', StringSplitOptions.RemoveEmptyEntries)
        .Take(2).Select(p => char.ToUpper(p[0])));
}
<aside class="hidden lg:flex w-60 flex-col border-r border-stone-200/70 bg-white">
    <div class="flex h-16 items-center gap-2.5 px-5">
        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-brand-700 text-white font-bold text-sm">A</div>
        <div class="leading-tight">
            <div class="text-[15px] font-semibold text-stone-900">AutoLedger</div>
            <div class="text-[11px] text-stone-400 font-medium">General Ledger</div>
        </div>
    </div>
    <nav class="flex-1 overflow-y-auto px-3 py-3 space-y-0.5 text-sm">
        <a href="@Url.Action("Index", "Dashboard")" class="@Cls("Dashboard")">
            <svg class="@IconCls("Dashboard")" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="9" rx="1.5"/><rect x="14" y="3" width="7" height="5" rx="1.5"/><rect x="14" y="12" width="7" height="9" rx="1.5"/><rect x="3" y="16" width="7" height="5" rx="1.5"/></svg> Dashboard</a>
        <a href="@Url.Action("Index", "Transactions")" class="@Cls("Transactions")">
            <svg class="@IconCls("Transactions")" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M3 6h18M3 12h18M3 18h18"/></svg> Transactions</a>
        <a href="@Url.Action("Create", "JournalEntries")" class="@Cls("JournalEntries")">
            <svg class="@IconCls("JournalEntries")" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M14 3v4a1 1 0 0 0 1 1h4"/><path d="M17 21H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h7l5 5v11a2 2 0 0 1-2 2z"/><path d="M12 11v6M9 14h6"/></svg> Journal Entry</a>
        <a href="@Url.Action("Index", "TrialBalance")" class="@Cls("TrialBalance")">
            <svg class="@IconCls("TrialBalance")" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M3 3v18h18"/><path d="M7 14l4-4 3 3 5-6"/></svg> Trial Balance</a>
        <a href="@Url.Action("IncomeStatement", "Reports")" class="@ClsA("Reports", "IncomeStatement")">
            <svg class="@IconClsA("Reports", "IncomeStatement")" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M4 4v16h16"/><path d="M8 16V9M12 16V6M16 16v-4"/></svg> Income Statement</a>
        <a href="@Url.Action("BalanceSheet", "Reports")" class="@ClsA("Reports", "BalanceSheet")">
            <svg class="@IconClsA("Reports", "BalanceSheet")" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M12 3v18M3 8h18M5 8l-2 6h4l-2-6zm14 0l-2 6h4l-2-6z"/></svg> Balance Sheet</a>
        <div class="my-2 border-t border-stone-100"></div>
        <a href="@Url.Action("Index", "Transactions", new { status = "PendingReview" })" class="flex items-center justify-between rounded-lg px-3 py-2 font-medium text-stone-500 hover:bg-stone-50 hover:text-stone-900">
            <span class="flex items-center gap-3"><svg class="h-[18px] w-[18px]" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="9"/></svg> Approvals</span>
            @if (pending > 0)
            {
                <span class="rounded-full bg-rose-100 px-1.5 py-0.5 text-[10px] font-semibold text-rose-700 tnum">@pending</span>
            }
        </a>
    </nav>
    <div class="p-3">
        <div class="flex items-center gap-3 rounded-lg px-2 py-2 hover:bg-stone-50">
            <div class="flex h-8 w-8 items-center justify-center rounded-full bg-brand-700 text-[12px] font-semibold text-white">@initials</div>
            <div class="leading-tight min-w-0">
                <div class="truncate text-[13px] font-medium text-stone-800">@displayName</div>
                <div class="truncate text-[11px] text-stone-400">@jobTitle</div>
            </div>
        </div>
    </div>
</aside>
