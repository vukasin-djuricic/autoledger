<header class="sticky top-0 z-20 flex h-16 items-center gap-4 border-b border-stone-200/70 bg-stone-50/90 px-6 backdrop-blur">
    <div class="lg:hidden flex h-8 w-8 items-center justify-center rounded-lg bg-brand-700 text-white font-bold text-sm">A</div>
    <div class="relative hidden sm:block w-full max-w-xs">
        <svg class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-stone-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
        <input type="text" placeholder="Search…" class="w-full rounded-lg border border-stone-200 bg-white py-2 pl-9 pr-3 text-sm text-stone-700 placeholder-stone-400 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-100" />
    </div>
    <div class="ml-auto flex items-center gap-2">
        <a href="@Url.Action("Create", "JournalEntries")" class="flex items-center gap-1.5 rounded-lg bg-brand-700 px-3.5 py-2 text-sm font-medium text-white shadow-sm hover:bg-brand-600">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg> New Entry</a>
        <form asp-controller="Account" asp-action="Logout" method="post" class="contents">
            @Html.AntiForgeryToken()
            <button type="submit" title="Sign out" class="flex h-9 w-9 items-center justify-center rounded-lg text-stone-400 hover:bg-stone-100 hover:text-stone-600">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><path d="M16 17l5-5-5-5"/><path d="M21 12H9"/></svg>
            </button>
        </form>
    </div>
</header>
