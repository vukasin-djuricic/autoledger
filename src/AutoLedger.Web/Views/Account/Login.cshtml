@model LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Sign in";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign in · AutoLedger</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-stone-100 text-stone-800 antialiased">
<div class="flex min-h-screen items-center justify-center px-4">
    <div class="w-full max-w-sm">
        <div class="mb-6 flex items-center gap-2.5">
            <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-brand-700 text-white font-bold">A</div>
            <div class="leading-tight">
                <div class="text-base font-semibold text-stone-900">AutoLedger</div>
                <div class="text-[11px] text-stone-400 font-medium">General Ledger</div>
            </div>
        </div>

        <div class="rounded-2xl border border-stone-200/80 bg-white p-7 shadow-sm">
            <h1 class="text-lg font-semibold text-stone-900">Sign in</h1>
            <p class="mt-1 text-sm text-stone-400">Welcome back. Enter your credentials to continue.</p>

            <form asp-action="Login" method="post" class="mt-6 space-y-4">
                <input type="hidden" asp-for="ReturnUrl" />
                <div asp-validation-summary="ModelOnly" class="rounded-lg bg-rose-50 px-3 py-2 text-sm text-rose-700 empty:hidden"></div>
                <div>
                    <label asp-for="Email" class="mb-1.5 block text-xs font-medium text-stone-500">Email</label>
                    <input asp-for="Email" autocomplete="username" class="w-full rounded-lg border border-stone-200 bg-white px-3 py-2 text-sm text-stone-700 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-100" />
                </div>
                <div>
                    <label asp-for="Password" class="mb-1.5 block text-xs font-medium text-stone-500">Password</label>
                    <input asp-for="Password" autocomplete="current-password" class="w-full rounded-lg border border-stone-200 bg-white px-3 py-2 text-sm text-stone-700 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-100" />
                </div>
                <label class="flex items-center gap-2 text-sm text-stone-600">
                    <input asp-for="RememberMe" type="checkbox" class="rounded border-stone-300 text-brand-600 focus:ring-brand-200" /> Remember me
                </label>
                <button type="submit" class="w-full rounded-lg bg-brand-700 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-brand-600">Sign in</button>
            </form>
        </div>

        <div class="mt-4 rounded-2xl border border-stone-200/80 bg-white p-4">
            <p class="mb-2.5 text-[11px] font-medium uppercase tracking-wide text-stone-400">Demo accounts</p>
            <div class="flex gap-2">
                <form asp-action="DemoLogin" method="post" class="flex-1">
                    <input type="hidden" name="role" value="Controller" />
                    <button class="w-full rounded-lg border border-stone-200 px-3 py-2 text-sm font-medium text-stone-700 hover:bg-stone-50">Sign in as Controller</button>
                </form>
                <form asp-action="DemoLogin" method="post" class="flex-1">
                    <input type="hidden" name="role" value="Clerk" />
                    <button class="w-full rounded-lg border border-stone-200 px-3 py-2 text-sm font-medium text-stone-700 hover:bg-stone-50">Sign in as Clerk</button>
                </form>
            </div>
        </div>
    </div>
</div>
</body>
</html>
